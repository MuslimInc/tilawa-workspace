RECITATION_VERIFIER_URL=https://your-verifier-service.example.com
# Use this only if the service follows the Alina FastAPI /speechrecognition API.
# Omit it for Tilawa's default JSON verifier contract.
RECITATION_VERIFIER_PROTOCOL=alina-fastapi
# Optional bearer token for a protected verifier service.
# RECITATION_VERIFIER_API_KEY=

# ── Quran Sessions callables ────────────────────────────────────────────────
# Enforce App Check on the stable-scope session callables (default false).
# QURAN_SESSIONS_ENFORCE_APP_CHECK=true
#
# Warm-instance floor for the pricing-quote callables only
# (getBookingPricingQuote + getBookingPricingQuotes). Eliminates the proven
# cold-start latency on the discovery→booking flow (2202ms cold → 362ms warm).
# Default 0 = no warm instances (no extra cost). Set to 1 for production.
# Env is loaded per project from functions/.env.<projectId> at deploy time.
QURAN_SESSIONS_MIN_INSTANCES=1
