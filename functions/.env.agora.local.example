# Local Agora RTC credentials for emulator / scripts only.
# Copy to `.env.agora.local` (gitignored) and fill from Agora Console.
#
# Production/staging Cloud Functions: use Secret Manager instead:
#   firebase functions:secrets:set AGORA_APP_ID AGORA_APP_CERTIFICATE --project quran-playera-app
#
# Do NOT commit real certificate values. Tokens are minted at runtime by
# `issueSessionRtcToken` — never paste temp console tokens here.

AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_primary_certificate
