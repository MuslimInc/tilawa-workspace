{
  "name": "tilawa-functions",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "seed:market-configs": "ts-node scripts/seedMarketConfigs.ts",
    "seed:market-configs:apply": "ts-node scripts/seedMarketConfigs.ts --apply",
    "admin:list-pending-applications": "ts-node scripts/listPendingTeacherApplications.ts",
    "admin:review-teacher-application": "ts-node scripts/reviewTeacherApplicationAdmin.ts"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.3.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
