# Local LiveKit credentials for emulator / scripts only.
# Copy to `.env.livekit.local` (gitignored) and fill from LiveKit Cloud console:
#   Project → Settings → Keys
#
# Staging project (MeMuslim/Tilawa): p_2n1vvcqjfqy
# WebSocket URL: wss://tilawa-7whzug8z.livekit.cloud
# SIP URI (v1 app out of scope): sip:2n1vvcqjfqy.sip.livekit.cloud
#
# Production/staging Cloud Functions: use Secret Manager instead:
#   firebase functions:secrets:set LIVEKIT_API_KEY --project <firebase-project-id>
#   firebase functions:secrets:set LIVEKIT_API_SECRET --project <firebase-project-id>
#   firebase functions:secrets:set LIVEKIT_URL --project <firebase-project-id>
#
# LIVEKIT_API_KEY and LIVEKIT_API_SECRET are both required for JWT minting.
# Project ID is not needed for JWT minting — only API key + secret + server URL.
# The API Secret is shown only once when you create a key — copy it from the console.
# Do NOT commit real secret values.

LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://tilawa-7whzug8z.livekit.cloud
