rules_version = '2';

// Tilawa client + Cloud Functions Firestore rules.
// Deploy: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function incomingUnchanged(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == resource.data[field];
    }

    function isVerifiedTeacherProfileOwner() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.verificationStatus == 'verified';
    }

    // Authorizes the teacher who owns the availability at {teacherId}.
    // Availability is keyed by the teacher's uid, so isOwner covers the normal
    // case; the second clause also allows keying by profile-doc id. exists()
    // guards the get() so a missing parent doc denies instead of erroring.
    function canEditTeacherAvailability(teacherId) {
      return ownsTeacherProfile(teacherId);
    }

    // Session/booking teacherId is the public profile doc id; owner is users/{userId}.
    function ownsTeacherProfile(teacherProfileId) {
      return isOwner(teacherProfileId)
        || (isSignedIn()
            && exists(/databases/$(database)/documents/quran_teacher_profiles/$(teacherProfileId))
            && get(/databases/$(database)/documents/quran_teacher_profiles/$(teacherProfileId)).data.userId == request.auth.uid);
    }

    function teacherProfileTrustFieldsUnchanged() {
      return incomingUnchanged('userId')
        && incomingUnchanged('verificationStatus')
        && incomingUnchanged('isActive')
        && incomingUnchanged('isPubliclyVisible')
        && incomingUnchanged('profileCompleteness')
        && incomingUnchanged('averageRating')
        && incomingUnchanged('reviewCount')
        && incomingUnchanged('totalSessionsCompleted')
        && incomingUnchanged('teacherStatus')
        && incomingUnchanged('manualPaymentPrice')
        && incomingUnchanged('createdAt');
    }

    function applicationModerationFieldsUnchanged() {
      return incomingUnchanged('reviewedBy')
        && incomingUnchanged('reviewedAt');
    }

    function clientCannotSelfApproveApplication() {
      return request.resource.data.status != 'approved'
        && request.resource.data.status != 'rejected'
        && request.resource.data.status != 'suspended'
        && request.resource.data.status != 'revoked';
    }

    function isBookingParticipant(bookingId) {
      return exists(/databases/$(database)/documents/quran_bookings/$(bookingId))
        && (
          get(/databases/$(database)/documents/quran_bookings/$(bookingId)).data.studentId == request.auth.uid
          || ownsTeacherProfile(
              get(/databases/$(database)/documents/quran_bookings/$(bookingId)).data.teacherId)
        );
    }

    function isSessionParticipant(sessionId) {
      return exists(/databases/$(database)/documents/quran_sessions/$(sessionId))
        && (
          get(/databases/$(database)/documents/quran_sessions/$(sessionId)).data.studentId == request.auth.uid
          || ownsTeacherProfile(
              get(/databases/$(database)/documents/quran_sessions/$(sessionId)).data.teacherId)
        );
    }

    // Lets clients probe by doc id without PERMISSION_DENIED on missing docs.
    function canReadBookingDoc(bookingId) {
      return isAdmin()
        || (isSignedIn()
            && (!exists(/databases/$(database)/documents/quran_bookings/$(bookingId))
                || resource.data.studentId == request.auth.uid
                || ownsTeacherProfile(resource.data.teacherId)));
    }

    function canReadSessionDoc(sessionId) {
      return isAdmin()
        || (isSignedIn()
            && (!exists(/databases/$(database)/documents/quran_sessions/$(sessionId))
                || resource.data.studentId == request.auth.uid
                || ownsTeacherProfile(resource.data.teacherId)));
    }

    // Remote in-app update policy (see InAppUpdateConfigDataSourceImpl).
    match /app_config/in_app_update {
      allow read: if true;
      allow write: if false;
    }

    // Subscription catalog — read-only for clients; seed via admin tools.
    match /subscription_plans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    // Quran Sessions market config — public read (country/city pickers run
    // during email registration before Auth exists); seed via admin tools.
    // Includes the per-country `cities` subcollection loaded by _loadCities().
    match /quran_session_market_configs/{countryCode} {
      allow read: if true;
      allow write: if false;

      match /cities/{cityId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Quran Sessions platform policy — public read (age thresholds for
    // registration wizard); seed via admin tools (global doc).
    match /quran_session_platform_config/{configId} {
      allow read: if true;
      allow write: if false;
    }

    // Quran Sessions write-bearing collections — SAFE SUBSET (Step 2).
    // Owner-scoped reads only; all client writes denied until the high-integrity
    // operations move to Cloud Functions (Admin SDK bypasses these rules).
    // Full design + write model: docs/security/quran_sessions_firestore_rules_draft.md

    // Teacher applications — applicant CRUD on own draft; moderation via CF.
    // Write model: docs/security/quran_sessions_teacher_application_write_model.md
    match /quran_teacher_applications/{applicationId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'draft'
        && clientCannotSelfApproveApplication()
        && !('reviewedBy' in request.resource.data)
        && !('reviewedAt' in request.resource.data);

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.status == 'draft'
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['draft', 'pending']
        && clientCannotSelfApproveApplication()
        && incomingUnchanged('userId')
        && applicationModerationFieldsUnchanged();

      allow delete: if false;
    }

    // Teacher profiles — public browse reads only when isPubliclyVisible;
    // owner reads own profile; trust fields CF-only.
    match /quran_teacher_profiles/{teacherId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || (isSignedIn() && resource.data.isPubliclyVisible == true);

      allow create: if false;

      // Verified owner may edit public marketplace fields only.
      allow update: if isVerifiedTeacherProfileOwner()
        && teacherProfileTrustFieldsUnchanged();

      allow delete: if false;

      // Pricing read by direct path (FirestoreTeacherDataSource); writes admin/CF.
      match /pricing/{marketId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      // Recurring weekly availability rules. Owner edits from the weekly editor;
      // any signed-in user reads (students derive bookable slots client-side).
      // Generated slots are never stored, so there is nothing booking-bearing
      // here — bookings/holds remain CF-only below.
      match /availability_config/{docId} {
        allow read: if isSignedIn();
        allow write: if canEditTeacherAvailability(teacherId);
      }

      // Dated overrides (vacations / busy / custom hours) — same ownership model.
      match /availability_overrides/{dateKey} {
        allow read: if isSignedIn();
        allow write: if canEditTeacherAvailability(teacherId);
      }

      // Legacy published slots — teacher-scoped direct delete (no collectionGroup).
      match /availability/{slotId} {
        allow read: if isSignedIn();
        allow create, update: if canEditTeacherAvailability(teacherId);
        allow delete: if canEditTeacherAvailability(teacherId)
          && (!('isBooked' in resource.data) || resource.data.isBooked == false);
      }
    }

    // Availability is read both directly and via a collectionGroup query, so it
    // needs a recursive-wildcard match (collection group queries are NOT covered
    // by a nested subcollection rule). Writes (slot booking) via CF.
    match /{path=**}/availability/{slotId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Bookings — admin or participant read; writes via CF.
    match /quran_bookings/{bookingId} {
      allow read: if canReadBookingDoc(bookingId)
        || (isSignedIn()
            && 'sessionId' in resource.data
            && isSessionParticipant(resource.data.sessionId));
      allow write: if false;
    }

    // Sessions — admin or participant read; writes via CF.
    match /quran_sessions/{sessionId} {
      allow read: if canReadSessionDoc(sessionId);
      allow write: if false;

      // Aggregated in-call tracking — participants read summary; CF writes only.
      match /callTracking/{docId} {
        allow read: if isAdmin() || isSessionParticipant(sessionId);
        allow write: if false;
      }

      // Raw call telemetry events — participant create own; CF may also write.
      match /call_events/{eventId} {
        allow read: if isAdmin() || isSessionParticipant(sessionId);
        allow create: if isSignedIn()
          && isSessionParticipant(sessionId)
          && request.resource.data.actorId == request.auth.uid
          && request.resource.data.sessionId == sessionId
          && request.resource.data.eventId == eventId
          && request.resource.data.eventType is string
          && request.resource.data.actorRole in ['teacher', 'student']
          && !('token' in request.resource.data)
          && !('joinToken' in request.resource.data);
        allow update, delete: if false;
      }
    }

    // Session audit timeline — participants and admins can read; CF writes only.
    match /quran_session_events/{eventId} {
      allow read: if isSignedIn()
        && (isAdmin()
            || resource.data.actorId == request.auth.uid
            || ('bookingId' in resource.data
                && isBookingParticipant(resource.data.bookingId))
            || ('aggregateId' in resource.data
                && isBookingParticipant(resource.data.aggregateId))
            || ('sessionId' in resource.data
                && isSessionParticipant(resource.data.sessionId)));
      allow write: if false;
    }

    // Compensation records — readable by booking participants/admins; CF writes only.
    match /quran_session_compensations/{compensationId} {
      allow read: if isSignedIn()
        && (isAdmin()
            || ('bookingId' in resource.data
                && isBookingParticipant(resource.data.bookingId)));
      allow write: if false;
    }

    // Refund ledger — readable by booking participants/admins; CF writes only.
    match /quran_session_refunds/{refundId} {
      allow read: if isSignedIn()
        && (isAdmin()
            || ('bookingId' in resource.data
                && isBookingParticipant(resource.data.bookingId)));
      allow write: if false;
    }

    // Disputes — readable by booking participants/admins; CF writes only.
    match /quran_session_disputes/{disputeId} {
      allow read: if isSignedIn()
        && (isAdmin()
            || ('bookingId' in resource.data
                && isBookingParticipant(resource.data.bookingId)));
      allow write: if false;
    }

    // Abuse / safety reports — admin and the reporter may read (NOT the reported
    // party); CF writes only.
    match /quran_session_reports/{reportId} {
      allow read: if isSignedIn()
        && (isAdmin() || resource.data.reporterUserId == request.auth.uid);
      allow write: if false;
    }

    // Idempotency operation markers — backend-only internal dedupe ledger.
    match /quran_session_operations/{operationId} {
      allow read, write: if false;
    }

    // Notification outbox and slot locks are backend-managed only.
    match /quran_session_notifications/{notificationId} {
      allow read, write: if false;
    }

    match /quran_reschedule_requests/{requestId} {
      allow read: if isSignedIn()
        && (isAdmin()
            || resource.data.requestedByUserId == request.auth.uid
            || isBookingParticipant(resource.data.bookingId));
      allow write: if false;
    }

    match /quran_slot_locks/{lockId} {
      // Public occupancy markers for availability (teacherId + slotId only).
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Denormalized session metrics — admin read only; CF writes only.
    match /quran_teacher_metrics/{teacherId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /quran_student_metrics/{studentId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Support purchase ledger — written by verifySupportPurchase Cloud Function.
    match /support_purchases/{tokenHash} {
      allow read, write: if false;
    }

    // Push campaigns — created in console; sendNotification function delivers.
    match /notifications/{notificationId} {
      allow read, write: if false;
    }

    function quranSessionsProfileEligibilityFieldUnchanged(field) {
      let beforeProfile = 'quranSessionsProfile' in resource.data
        ? resource.data.quranSessionsProfile
        : {};
      let afterProfile = 'quranSessionsProfile' in request.resource.data
        ? request.resource.data.quranSessionsProfile
        : {};
      return !(field in beforeProfile && beforeProfile[field] != null)
        || afterProfile.get(field, null) == beforeProfile.get(field, null);
    }

    function quranSessionsProfileEligibilityUnchanged() {
      return quranSessionsProfileEligibilityFieldUnchanged('gender')
        && quranSessionsProfileEligibilityFieldUnchanged('dateOfBirth')
        && quranSessionsProfileEligibilityFieldUnchanged('countryCode')
        && quranSessionsProfileEligibilityFieldUnchanged('cityId')
        && quranSessionsProfileEligibilityFieldUnchanged('guardianId')
        && quranSessionsProfileEligibilityFieldUnchanged('role')
        && quranSessionsProfileEligibilityFieldUnchanged('canApplyAsTeacher');
    }

    function quranSessionsProfileModerationUnchanged() {
      let beforeProfile = 'quranSessionsProfile' in resource.data
        ? resource.data.quranSessionsProfile
        : {};
      let afterProfile = 'quranSessionsProfile' in request.resource.data
        ? request.resource.data.quranSessionsProfile
        : {};
      return afterProfile.get('accountStatus', 'active')
          == beforeProfile.get('accountStatus', 'active')
        && afterProfile.get('restrictionReason', null)
          == beforeProfile.get('restrictionReason', null);
    }

    function quranSessionsProfileModerationSafeOnCreate() {
      return !('quranSessionsProfile' in request.resource.data)
        || request.resource.data.quranSessionsProfile.get('accountStatus', 'active') == 'active';
    }

    function sessionFieldsUnchanged() {
      let before = resource.data;
      let after = request.resource.data;
      return after.get('session', {}) == before.get('session', {})
          && after.get('notifications', {}) == before.get('notifications', {});
    }

    // Deletion envelope (requestUserDeletion CF) is CF-only: no client —
    // including admin clients — may add, change, or remove it. get(...,null)
    // equality blocks removal too, unlike incomingUnchanged.
    function deletionEnvelopeUntouched() {
      return request.resource.data.get('accountStatus', null)
          == resource.data.get('accountStatus', null)
        && request.resource.data.get('deletion', null)
          == resource.data.get('deletion', null);
    }

    function deletionEnvelopeAbsentOnCreate() {
      return !('deletion' in request.resource.data)
        && !('accountStatus' in request.resource.data);
    }

    match /users/{userId} {
      allow get: if isAdmin() || isOwner(userId);
      allow list: if isAdmin();
      allow create: if isOwner(userId)
        && quranSessionsProfileModerationSafeOnCreate()
        && deletionEnvelopeAbsentOnCreate();
      allow update: if (isAdmin()
          || (isOwner(userId)
              && quranSessionsProfileModerationUnchanged()
              && quranSessionsProfileEligibilityUnchanged()
              && sessionFieldsUnchanged()))
        && deletionEnvelopeUntouched();
      allow delete: if false;

      match /fcm_tokens/{tokenId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /favorites/{favoriteDoc}/items/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /premium/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /purchases/{purchaseId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /cancellations/{cancellationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // Wallet — owner read; admin read; CF writes only.
    match /user_wallets/{walletId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /wallet_transactions/{transactionId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // Payment intents / transactions — CF writes only; admin read.
    match /quran_payment_intents/{paymentIntentId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /quran_payment_transactions/{paymentTransactionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Admin-initiated user deletion (docs/plans/admin_user_deletion_plan.md).
    // Purge state machine keyed by target uid — admin read; CF writes only.
    match /user_deletion_state/{userId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Append-only deletion audit log — admin read; CF writes only.
    match /user_deletion_audit/{auditId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

