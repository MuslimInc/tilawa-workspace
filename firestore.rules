rules_version = '2';

// Tilawa client + Cloud Functions Firestore rules.
// Deploy: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Remote in-app update policy (see InAppUpdateConfigDataSourceImpl).
    match /app_config/in_app_update {
      allow read: if true;
      allow write: if false;
    }

    // Client startup telemetry (see docs/observability/startup_health_logs.md).
    match /app_startup_logs/{logId} {
      allow create: if request.resource.data.keys().hasAll([
          'level',
          'event',
          'session_id',
          'client_timestamp_ms',
        ])
        && request.resource.data.level in ['info', 'error']
        && request.resource.data.event in [
          'startup_phase',
          'startup_failed',
          'startup_completed',
        ];
      allow read, update, delete: if false;
    }

    // Subscription catalog — read-only for clients; seed via admin tools.
    match /subscription_plans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    // Support purchase ledger — written by verifySupportPurchase Cloud Function.
    match /support_purchases/{tokenHash} {
      allow read, write: if false;
    }

    // Push campaigns — created in console; sendNotification function delivers.
    match /notifications/{notificationId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /fcm_tokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }

      match /favorites/{favoriteDoc}/items/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /premium/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /purchases/{purchaseId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /cancellations/{cancellationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }
  }
}
