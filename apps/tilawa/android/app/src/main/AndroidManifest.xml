<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Google Play Billing (Support Tilawa one-time products) -->
    <uses-permission android:name="com.android.vending.BILLING" />
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <!-- Agora screen-sharing AAR excluded in build.gradle; strip merged projection. -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"
        tools:node="remove" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- For Android 13+ (API 33+) notification permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- Android 12+ (API 31+) exact alarms. SCHEDULE_EXACT_ALARM requires the
         user to grant "Alarms & Reminders" permission on first use; the prayer
         scheduler checks canScheduleExactAlarms() and falls back gracefully to
         inexact alarms when denied, so prayer notifications still fire (±a few
         minutes). USE_EXACT_ALARM was replaced to comply with Play Store policy
         for apps not categorised as alarm/clock apps. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Required for prayer-alerts battery-optimization whitelist (permission_handler
         + Settings.ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Queries for Google Play Services + Credential Manager on Android 11+.
         Required so Transsion/XOS HubCore does not hide the CM overlay from
         package visibility filters. GMS must stay visible for google_sign_in
         7.x (HiddenActivity / androidx.credentials). -->
    <queries>
        <package android:name="com.google.android.gms" />
        <package android:name="com.android.vending" />
        <intent>
            <action android:name="androidx.credentials.CREDENTIAL_PROVIDER" />
        </intent>
        <!-- Android 11+ package visibility for https/http links (e.g. Google Meet). -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
    </queries>

    <!-- Location permissions for Qibla feature -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Explicitly remove AD_ID permission added by Firebase Analytics since we don't use ads -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_ATTRIBUTION" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_AD_ID" tools:node="remove" />

    <!-- Workaround: disable Android 13+ predictive back until Flutter handles
         invalid swipeEdge values without crashing (RangeError in
         PredictiveBackEvent.fromMap). See flutter/flutter#186168.
         Re-enable when fixed in our Flutter SDK. -->
    <application
        android:label="@string/app_name"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:extractNativeLibs="false"
        android:enableOnBackInvokedCallback="false">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|layoutDirection|fontScale|screenLayout|density"
            android:screenOrientation="portrait"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:windowLayoutInDisplayCutoutMode="shortEdges"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            tools:ignore="Instantiatable">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"
                />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <service
            android:name="com.ryanheise.audioservice.AudioService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true"
            tools:ignore="Instantiatable">
            <intent-filter>
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>

        <receiver
            android:name="com.ryanheise.audioservice.MediaButtonReceiver"
            android:exported="true"
            tools:ignore="Instantiatable">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
        </intent-filter>
        </receiver>

        <!-- Flutter Local Notifications -->
        <receiver android:exported="false" android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver" />
        <receiver android:exported="false" android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- Prayer alarms: re-arm WorkManager rescheduler after reboot, app
             update, time/timezone change. Also covers direct-boot exit. -->
        <receiver
            android:name=".prayer.PrayerBootReceiver"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.DATE_CHANGED"/>
                <action android:name="android.intent.action.TIMEZONE_CHANGED"/>
                <action android:name="android.intent.action.TIME_SET"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- Adhan alarm receiver: fires at prayer time and starts the
             foreground playback service. Internal only. -->
        <receiver
            android:name=".prayer.AdhanReceiver"
            android:exported="false"
            android:directBootAware="true"/>

        <!-- Adhan playback foreground service. mediaPlayback type is required
             on Android 14+ (API 34+) for the MediaPlayer-backed playback. -->
        <service
            android:name=".prayer.AdhanPlaybackService"
            android:exported="false"
            android:directBootAware="true"
            android:foregroundServiceType="mediaPlayback"/>

        <!-- Prayer times home-screen widget (spec 041, P1). APPWIDGET_UPDATE
             requires exported=true; the custom refresh action stays safe
             because the provider only re-reads its own stored snapshot. -->
        <receiver
            android:name=".prayer.widget.PrayerTimesWidgetProvider"
            android:exported="true"
            android:label="@string/widget_prayer_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/prayer_times_widget_info" />
        </receiver>

        <!-- Ayah of the Day home-screen widget (spec 041, US2). The custom
             refresh action is delivered package-scoped from the method
             channel after each snapshot publish. -->
        <receiver
            android:name=".widget.ayah.AyahOfDayWidgetProvider"
            android:exported="true"
            android:label="@string/widget_ayah_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.tilawa.app.widget.AYAH.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/ayah_of_day_widget_info" />
        </receiver>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Use Skia instead of Impeller on Android (glyph atlas / raster jank). -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />


        <!-- Firebase Crashlytics Configuration -->
        <!-- Enabled by default; CrashlyticsService disables it at runtime for
             non-release builds so debug crashes don't pollute dashboards. -->
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="true" />
        <meta-data
            android:name="com.google.firebase.crashlytics.RequireBuildId"
            android:value="false" />

        <!-- FCM Default Notification Metadata -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_accent" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="high_importance_channel" />

        <!-- Flutter Downloader Notification Icon -->
        <meta-data
            android:name="vn.hunghd.flutterdownloader.NOTIFICATION_ICON"
            android:resource="@drawable/ic_notification" />

        <!-- Agora screen-sharing (excluded); avoid Play FGS mediaProjection declaration. -->
        <service
            android:name="io.agora.rtc2.extensions.MediaProjectionMgr$LocalScreenSharingService"
            tools:node="remove" />
        <activity
            android:name="io.agora.rtc2.extensions.MediaProjectionMgr$LocalScreenCaptureAssistantActivity"
            tools:node="remove" />

    </application>
</manifest>
