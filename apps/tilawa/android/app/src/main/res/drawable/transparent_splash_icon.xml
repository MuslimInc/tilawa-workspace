<?xml version="1.0" encoding="utf-8"?>
<!-- Invisible splash icon: Android 12+ only allows a flat window color here.
     The wordmark is drawn by Flutter at @dimen/splash_logo_size so it is not
     masked or scaled differently from the launcher adaptive icon animation. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <size
        android:width="48dp"
        android:height="48dp" />
</shape>
