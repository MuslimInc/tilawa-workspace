<?xml version="1.0" encoding="utf-8"?>
<!-- Fixed 288dp splash mark — same box as Flutter [AppColors.launchSplashLogoSize].
     Foreground-only on @color/launch_background (not @mipmap/ic_launcher). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="@dimen/splash_logo_size"
        android:height="@dimen/splash_logo_size"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_icon_bitmap" />
    </item>
</layer-list>
