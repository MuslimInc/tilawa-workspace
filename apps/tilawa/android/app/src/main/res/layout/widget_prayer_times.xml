<?xml version="1.0" encoding="utf-8"?>
<!-- Prayer times home-screen widget (spec 041, P1).
     RemoteViews-safe views only (LinearLayout/TextView/Chronometer).

     Default android:text values double as the widget-picker preview
     (previewLayout inflates this XML as-is); the provider overwrites every
     field at runtime, and the Chronometer stays hidden until real data
     arrives so the preview never shows a dead "00:00". -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/widget_empty_hint"
        android:textColor="@color/widget_text_primary"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <!-- Header: location · next prayer + live countdown -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/widget_prayer_title"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/widget_next_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:maxLines="1"
                android:text="@string/widget_preview_next"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Chronometer
                android:id="@+id/widget_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_stale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Five prayer cells: each column centers a compact pill so the
             next-prayer highlight hugs the name+time instead of stretching. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout style="@style/PrayerWidgetCellColumn">
                <LinearLayout
                    android:id="@+id/widget_cell_fajr"
                    style="@style/PrayerWidgetCellPill">
                    <TextView
                        android:id="@+id/widget_name_fajr"
                        style="@style/PrayerWidgetCellName"
                        android:text="@string/prayer_fajr" />
                    <TextView
                        android:id="@+id/widget_time_fajr"
                        style="@style/PrayerWidgetCellTime"
                        android:text="@string/widget_preview_time_fajr" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/PrayerWidgetCellColumn">
                <LinearLayout
                    android:id="@+id/widget_cell_dhuhr"
                    style="@style/PrayerWidgetCellPill">
                    <TextView
                        android:id="@+id/widget_name_dhuhr"
                        style="@style/PrayerWidgetCellName"
                        android:text="@string/prayer_dhuhr" />
                    <TextView
                        android:id="@+id/widget_time_dhuhr"
                        style="@style/PrayerWidgetCellTime"
                        android:text="@string/widget_preview_time_dhuhr" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/PrayerWidgetCellColumn">
                <LinearLayout
                    android:id="@+id/widget_cell_asr"
                    style="@style/PrayerWidgetCellPill">
                    <TextView
                        android:id="@+id/widget_name_asr"
                        style="@style/PrayerWidgetCellName"
                        android:text="@string/prayer_asr" />
                    <TextView
                        android:id="@+id/widget_time_asr"
                        style="@style/PrayerWidgetCellTime"
                        android:text="@string/widget_preview_time_asr" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/PrayerWidgetCellColumn">
                <LinearLayout
                    android:id="@+id/widget_cell_maghrib"
                    style="@style/PrayerWidgetCellPill">
                    <TextView
                        android:id="@+id/widget_name_maghrib"
                        style="@style/PrayerWidgetCellName"
                        android:text="@string/prayer_maghrib" />
                    <TextView
                        android:id="@+id/widget_time_maghrib"
                        style="@style/PrayerWidgetCellTime"
                        android:text="@string/widget_preview_time_maghrib" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/PrayerWidgetCellColumn">
                <LinearLayout
                    android:id="@+id/widget_cell_isha"
                    style="@style/PrayerWidgetCellPill">
                    <TextView
                        android:id="@+id/widget_name_isha"
                        style="@style/PrayerWidgetCellName"
                        android:text="@string/prayer_isha" />
                    <TextView
                        android:id="@+id/widget_time_isha"
                        style="@style/PrayerWidgetCellTime"
                        android:text="@string/widget_preview_time_isha" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
