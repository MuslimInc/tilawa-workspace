<?xml version="1.0" encoding="utf-8"?>
<!-- Ayah of the Day widget (spec 041, US2). The verse is a pre-rendered QCF
     PNG set at runtime; the default ﷽ text only serves the picker preview. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ayah_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">

    <TextView
        android:id="@+id/ayah_widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/widget_ayah_preview_glyph"
        android:textColor="@color/widget_text_primary"
        android:textSize="28sp" />

    <!-- The artifact is tight-cropped to the text block by the renderer and
         wrap_content + adjustViewBounds keeps the view hugging it, so the
         verse and caption center together as one compact block. -->
    <ImageView
        android:id="@+id/ayah_widget_image"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:contentDescription="@string/widget_ayah_label"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <TextView
        android:id="@+id/ayah_widget_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/widget_ayah_preview_caption"
        android:textColor="@color/widget_text_secondary"
        android:textSize="11sp" />
</LinearLayout>
