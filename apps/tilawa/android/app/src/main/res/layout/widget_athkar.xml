<?xml version="1.0" encoding="utf-8"?>
<!-- Morning/Evening athkar widget (spec 041, US3). Tapping the dhikr body
     advances to the next item; tapping elsewhere opens the athkar flow.
     Default texts serve the picker preview only. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/athkar_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">

    <TextView
        android:id="@+id/athkar_widget_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/widget_athkar_empty_hint"
        android:textColor="@color/widget_text_primary"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/athkar_widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header: set title + progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/athkar_widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:text="@string/widget_athkar_preview_title"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/athkar_widget_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_athkar_preview_progress"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Dhikr body: tap to advance -->
        <LinearLayout
            android:id="@+id/athkar_widget_body"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/athkar_widget_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:lineSpacingMultiplier="1.25"
                android:maxLines="5"
                android:text="@string/widget_athkar_preview_text"
                android:textColor="@color/widget_text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/athkar_widget_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/widget_cell_highlight"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:text="@string/widget_athkar_preview_count"
                android:textColor="@color/widget_text_primary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
