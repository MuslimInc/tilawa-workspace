<?xml version="1.0" encoding="utf-8"?>
<!-- Athkar widget metadata (spec 041, US3). Window flips use one inexact
     alarm at the morning/evening boundary; updatePeriodMillis is the
     OS-managed backstop. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/widget_athkar_description"
    android:initialLayout="@layout/widget_athkar"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:minResizeWidth="180dp"
    android:minResizeHeight="70dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:previewLayout="@layout/widget_athkar"
    android:resizeMode="horizontal|vertical"
    android:updatePeriodMillis="3600000"
    android:widgetCategory="home_screen" />
