+std::string CanonicalizeFamilyName(std::string family_name) {
+  std::transform(family_name.begin(), family_name.end(), family_name.begin(),
+                 [](char c) { return (c & 0x80) ? c : ::tolower(c); });
+  return family_name;
+}
+
+std::string ResolveFamilyName(const sk_sp<SkTypeface>& typeface,
+                              const std::string& family_name) {
+  if (!family_name.empty()) {
+    return family_name;
+  }
+  if (!typeface) {
+    return "";
+  }
+
+  SkString sk_family_name;
+  typeface->getFamilyName(&sk_family_name);
+  return std::string(sk_family_name.c_str(), sk_family_name.size());
+}
+
+std::size_t HashFontBytes(const tonic::Uint8List& font_data) {
+  const auto bytes = std::string_view(
+      reinterpret_cast<const char*>(font_data.data()), font_data.num_elements());
+  return fml::HashCombine(std::hash<std::string_view>{}(bytes), bytes.size());
+}
