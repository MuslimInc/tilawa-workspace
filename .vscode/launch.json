{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MeMuslim Dev",
            "request": "launch",
            "type": "dart",
            "cwd": "${workspaceFolder}/apps/tilawa",
            "program": "lib/main.dart",
            "flutterMode": "debug",
            "toolArgs": [
                "--flavor",
                "development",
                "--dart-define-from-file=env/development.json"
            ]
        },
        {
            "name": "MeMuslim Staging",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "cwd": "${workspaceFolder}/apps/tilawa",
