+TEST_F(PainterTest, ReusesTextFrameAcrossPaintsImpeller) {
+  PretendImpellerIsEnabled(true);
+
+  auto paragraph = makeParagraph(makeStyle(), u"Hello World!");
+
+  auto first_builder = DisplayListBuilder();
+  paragraph->Layout(10000);
+  paragraph->Paint(&first_builder, 0, 0);
+  auto first_recorder = DlOpRecorder();
+  first_builder.Build()->Dispatch(first_recorder);
+
+  auto second_builder = DisplayListBuilder();
+  paragraph->Paint(&second_builder, 0, 0);
+  auto second_recorder = DlOpRecorder();
+  second_builder.Build()->Dispatch(second_recorder);
+
+  EXPECT_EQ(first_recorder.textFrameCount(), 1);
+  EXPECT_EQ(second_recorder.textFrameCount(), 1);
+  EXPECT_EQ(first_recorder.textFrameAt(0), second_recorder.textFrameAt(0));
+}
+
+TEST_F(PainterTest, ClearsTextFrameCacheWhenLayoutChangesImpeller) {
+  PretendImpellerIsEnabled(true);
+
+  auto paragraph =
+      makeParagraph(makeStyle(), u"Hello World! Hello World! Hello World!");
+
+  auto first_builder = DisplayListBuilder();
+  paragraph->Layout(10000);
+  paragraph->Paint(&first_builder, 0, 0);
+  auto first_recorder = DlOpRecorder();
+  first_builder.Build()->Dispatch(first_recorder);
+
+  auto second_builder = DisplayListBuilder();
+  paragraph->Layout(20);
+  paragraph->Paint(&second_builder, 0, 0);
+  auto second_recorder = DlOpRecorder();
+  second_builder.Build()->Dispatch(second_recorder);
+
+  EXPECT_EQ(first_recorder.textFrameCount(), 1);
+  EXPECT_EQ(second_recorder.textFrameCount(), 1);
+  EXPECT_NE(first_recorder.textFrameAt(0), second_recorder.textFrameAt(0));
+}
