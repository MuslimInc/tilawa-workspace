+std::shared_ptr<impeller::TextFrame> ParagraphSkia::GetOrCreateTextFrame(
+    const sk_sp<SkTextBlob>& blob) {
+  if (!blob) {
+    return nullptr;
+  }
+  const SkTextBlob* blob_key = blob.get();
+  auto cached = text_frame_cache_.find(blob_key);
+  if (cached != text_frame_cache_.end()) {
+    return cached->second;
+  }
+
+  auto frame = impeller::MakeTextFrameFromTextBlobSkia(blob);
+  text_frame_cache_[blob_key] = frame;
+  return frame;
+}
